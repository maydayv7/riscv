{
  "name": "riscv_mem_generator",
  "version": "1.0.0",
  "config": {},
  "dependencies": {},
  "devDependencies": {},
  "xpack": {
    "minimumXpmRequired": "0.21.4",
    "dependencies": {},
    "devDependencies": {
      "@xpack-dev-tools/riscv-none-elf-gcc": {
        "specifier": "15.2.0-1.1",
        "local": "link",
        "platforms": "all"
      }
    },
    "properties": {},
    "actions": {
      "sim-addition": "mingw32-make -C simulation addition",
      "sim-sort": "mingw32-make -C simulation sort",
      "sim-negative": "mingw32-make -C simulation negative",

      "build-addition": "mingw32-make -C mem_generator addition",
      "build-sort": "mingw32-make -C mem_generator sort",
      "build-negative": "mingw32-make -C mem_generator negative",

      "clean": "mingw32-make -C mem_generator clean && mingw32-make -C simulation clean"
    },
    "buildConfigurations": {}
  }
}
